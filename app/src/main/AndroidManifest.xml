<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    tools:ignore="Typos">

    <queries>
        <package android:name="com.whatsapp" />
        <package android:name="com.whatsapp.w4b" />
        <intent>
            <action android:name="com.whatsapp.intent.action.ENABLE_STICKER_PACK" />
        </intent>
    </queries>

    <!-- NEW: Required for the Private Browser to access the web -->
    <uses-permission android:name="android.permission.INTERNET" />

    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Suppressed the generic Foreground Service declaration warning -->
    <uses-permission
        android:name="android.permission.FOREGROUND_SERVICE"
        tools:ignore="ForegroundServicePermission" />

    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.OwnPhotoONWall">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ImagePickerActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".GearClickActivity"
            android:theme="@android:style/Theme.Translucent.NoTitleBar"
            android:exported="false"
            android:excludeFromRecents="true"
            android:taskAffinity="" />

        <activity
            android:name=".DrawingActivity"
            android:exported="false" />

        <activity
            android:name=".WidgetGalleryActivity"
            android:exported="false" />

        <activity
            android:name=".GamesGalleryActivity"
            android:exported="false" />

        <!-- Suppressed the Portrait lock warning -->
        <activity
            android:name=".SnakeGameActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            tools:ignore="LockedOrientationActivity" />

        <!-- Flappy Bird Game Activity -->
        <activity
            android:name=".FlappyBirdActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.OwnPhotoONWall"
            tools:ignore="LockedOrientationActivity" />

        <!-- Tetris Game Activity -->
        <activity
            android:name=".TetrisActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.OwnPhotoONWall"
            tools:ignore="LockedOrientationActivity" />

        <!-- Breakout Game Activity -->
        <activity
            android:name=".BreakoutActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.OwnPhotoONWall"
            tools:ignore="LockedOrientationActivity" />

        <activity
            android:name=".ToolsGalleryActivity"
            android:exported="false" />

        <!-- NEW: Utilities Gallery -->
        <activity
            android:name=".UtilitiesGalleryActivity"
            android:exported="false" />

        <!-- NEW: Hyper-Secure Private Browser Activity -->
        <activity
            android:name=".PrivateBrowserActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".StickerMakerActivity"
            android:exported="false" />

        <activity
            android:name=".ImageEditorActivity"
            android:exported="true" />

        <!-- Advanced Canvas Studio -->
        <activity
            android:name=".AdvancedCanvasActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            tools:ignore="LockedOrientationActivity" />

        <!-- Clone Tool Studio -->
        <activity
            android:name=".CloneActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            tools:ignore="LockedOrientationActivity" />

        <!-- PDF Studio Activities -->
        <activity
            android:name=".PdfStudioActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            tools:ignore="LockedOrientationActivity" />

        <activity
            android:name=".PdfGalleryActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            tools:ignore="LockedOrientationActivity" />

        <provider
            android:name=".StickerContentProvider"
            android:authorities="com.example.ownphotoonwall.stickercontentprovider"
            android:enabled="true"
            android:exported="true"
            android:readPermission="com.whatsapp.sticker.READ" />

        <receiver
            android:name=".Photowidget"
            android:label="Add Photo"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/photowidget_info" />
        </receiver>

        <receiver
            android:name=".SnakeWidget"
            android:label="Auto Snake Widget"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="TOGGLE_SNAKE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/snake_widget_info" />
        </receiver>

        <receiver
            android:name=".WaterWidgetProvider"
            android:label="Water Widget"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="TOGGLE_WATER" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/water_widget_info" />
        </receiver>

        <receiver
            android:name=".HourglassWidget"
            android:label="Hourglass Widget"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="TOGGLE_HOURGLASS" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/hourglass_widget_info" />
        </receiver>

        <receiver
            android:name=".CoinWidget"
            android:label="Coin Toss Widget"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/coin_widget_info" />
        </receiver>

        <receiver
            android:name=".GearWidgetProvider"
            android:label="Fidget Gear Widget"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.example.ownphotoonwall.ACTION_ROTATE_GEAR" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/gear_widget_info" />
        </receiver>

        <receiver
            android:name=".MazeWidgetProvider"
            android:label="Maze Widget"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.example.ownphotoonwall.TOGGLE_MAZE" />
                <action android:name="android.intent.action.CONFIGURATION_CHANGED" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/maze_widget_info" />
        </receiver>

        <receiver
            android:name=".DrawingWidgetProvider"
            android:label="Drawing Widget"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/drawing_widget_info" />
        </receiver>

        <service
            android:name=".SnakeService"
            android:exported="false"
            android:foregroundServiceType="specialUse"
            tools:targetApi="upside_down_cake">
            <property android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE" android:value="Widget state management"/>
        </service>

        <service
            android:name=".WaterSensorService"
            android:exported="false"
            android:foregroundServiceType="specialUse"
            tools:targetApi="upside_down_cake">
            <property android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE" android:value="Interactive widget physics"/>
        </service>

        <service
            android:name=".HourglassService"
            android:exported="false"
            android:foregroundServiceType="specialUse"
            tools:targetApi="upside_down_cake">
            <property android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE" android:value="Widget animation state"/>
        </service>

        <service
            android:name=".MazeGameService"
            android:exported="false"
            android:foregroundServiceType="specialUse"
            android:configChanges="uiMode|orientation|screenSize"
            tools:targetApi="upside_down_cake">
            <property android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE" android:value="Widget sensor tracking"/>
        </service>

    </application>
</manifest>