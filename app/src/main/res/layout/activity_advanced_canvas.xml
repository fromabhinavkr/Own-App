<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/canvasRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="#1C1C1E">

    <FrameLayout
        android:id="@+id/drawingContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_margin="0dp"
        android:background="#000000">
    </FrameLayout>

    <ScrollView
        android:id="@+id/rightBrushesPanel"
        android:layout_width="200dp"
        android:layout_height="match_parent"
        android:layout_alignParentEnd="true"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="100dp"
        android:layout_marginTop="16dp"
        android:visibility="gone"
        android:elevation="8dp"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/brushListContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp">
        </LinearLayout>
    </ScrollView>

    <ScrollView
        android:id="@+id/leftSettingsPanel"
        android:layout_width="240dp"
        android:layout_height="match_parent"
        android:layout_alignParentStart="true"
        android:layout_marginStart="8dp"
        android:layout_marginBottom="100dp"
        android:layout_marginTop="16dp"
        android:visibility="gone"
        android:elevation="8dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <androidx.appcompat.widget.AppCompatButton android:id="@+id/btnCanvasSave" android:layout_width="match_parent" android:layout_height="wrap_content" android:backgroundTint="#34C759" android:textColor="#FFFFFF" android:text="Save" android:textAllCaps="false" android:textStyle="bold" android:layout_marginBottom="8dp"/>
            <androidx.appcompat.widget.AppCompatButton android:id="@+id/btnCanvasCancel" android:layout_width="match_parent" android:layout_height="wrap_content" android:backgroundTint="#FF3B30" android:textColor="#FFFFFF" android:text="Cancel" android:textAllCaps="false" android:layout_marginBottom="8dp"/>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="12dp">
                <androidx.appcompat.widget.AppCompatButton android:id="@+id/btnCanvasUndo" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:backgroundTint="#4A90E2" android:textColor="#FFFFFF" android:text="Undo" android:textAllCaps="false" android:layout_marginEnd="4dp"/>
                <androidx.appcompat.widget.AppCompatButton android:id="@+id/btnCanvasRedo" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:backgroundTint="#4A90E2" android:textColor="#FFFFFF" android:text="Redo" android:textAllCaps="false" android:layout_marginStart="4dp"/>
            </LinearLayout>

            <androidx.appcompat.widget.AppCompatButton android:id="@+id/btnCanvasZoom" android:layout_width="match_parent" android:layout_height="wrap_content" android:backgroundTint="#4A90E2" android:textColor="#FFFFFF" android:text="Zoom: OFF" android:textAllCaps="false" android:textStyle="bold" android:layout_marginBottom="8dp"/>
            <androidx.appcompat.widget.AppCompatButton android:id="@+id/btnCanvasGrid" android:layout_width="match_parent" android:layout_height="wrap_content" android:backgroundTint="#4A90E2" android:textColor="#FFFFFF" android:text="Grid: OFF" android:textAllCaps="false" android:textStyle="bold" android:layout_marginBottom="24dp"/>

            <TextView android:id="@+id/tvSettingsTitle" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Brush Settings" android:textStyle="bold" android:textSize="16sp" android:gravity="center" android:layout_marginBottom="12dp"/>

            <TextView android:id="@+id/tvColorLabel" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Color (Long-Press canvas to pick!)" android:textSize="12sp" android:textStyle="bold"/>
            <FrameLayout android:id="@+id/colorWheelContainer" android:layout_width="match_parent" android:layout_height="180dp" android:layout_marginBottom="8dp"/>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center" android:layout_marginBottom="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="HEX: " android:textStyle="bold"/>
                <EditText android:id="@+id/etCanvasHexCode" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="text" android:maxLines="1" android:text="#FF0000" android:textSize="14sp"/>
            </LinearLayout>

            <TextView android:id="@+id/tvSizeLabel" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Size" android:textStyle="bold"/>
            <com.google.android.material.slider.Slider android:id="@+id/slSize" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginStart="-12dp" android:layout_marginEnd="-12dp" android:alpha="0.8" android:valueFrom="1.0" android:valueTo="300.0" android:value="10.0"/>

            <TextView android:id="@+id/tvOpacityLabel" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Opacity" android:textStyle="bold"/>
            <com.google.android.material.slider.Slider android:id="@+id/slOpacity" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginStart="-12dp" android:layout_marginEnd="-12dp" android:alpha="0.8" android:valueFrom="1.0" android:valueTo="100.0" android:value="100.0"/>

            <TextView android:id="@+id/tvHardnessLabel" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Hardness" android:textStyle="bold"/>
            <com.google.android.material.slider.Slider android:id="@+id/slHardness" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginStart="-12dp" android:layout_marginEnd="-12dp" android:alpha="0.8" android:valueFrom="0.0" android:valueTo="100.0" android:value="100.0"/>

            <TextView android:id="@+id/tvSmoothingLabel" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Smoothing" android:textStyle="bold"/>
            <com.google.android.material.slider.Slider android:id="@+id/slSmoothing" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginStart="-12dp" android:layout_marginEnd="-12dp" android:alpha="0.8" android:valueFrom="0.0" android:valueTo="100.0" android:value="50.0"/>
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/bottomMenuBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="32dp"
        android:orientation="horizontal"
        android:gravity="center">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnToggleSettings"
            android:layout_width="130dp"
            android:layout_height="50dp"
            android:layout_marginEnd="8dp"
            android:text="Settings"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textSize="16sp"
            android:background="@null"
            android:elevation="0dp"
            android:stateListAnimator="@null"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnToggleTools"
            android:layout_width="130dp"
            android:layout_height="50dp"
            android:layout_marginStart="8dp"
            android:text="Brushes"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textSize="16sp"
            android:background="@null"
            android:elevation="0dp"
            android:stateListAnimator="@null"/>
    </LinearLayout>

</RelativeLayout>