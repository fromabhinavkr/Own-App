<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center">

    <RelativeLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/snake_bg_rounded"
        android:clipToOutline="true">

        <ImageView
            android:id="@+id/widget_image_view"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:adjustViewBounds="true"
            android:scaleType="fitCenter"
            android:clickable="true"
            android:contentDescription="Snake Screen" />

        <TextView
            android:id="@+id/widget_title_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Own's Auto Snake"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btn_toggle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:layout_alignParentEnd="true"
            android:layout_alignParentRight="true"
            android:layout_margin="12dp"
            android:text="Start"
            android:textSize="10sp"
            android:padding="6dp"
            android:minHeight="0dp"
            android:minWidth="0dp"
            android:backgroundTint="#44FFFFFF"
            android:textColor="#FFFFFF" />

    </RelativeLayout>
</RelativeLayout>