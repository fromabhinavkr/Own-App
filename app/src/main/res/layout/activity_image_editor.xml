<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/editorRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:ignore="HardcodedText,ButtonBarStyle">

    <!-- Top Bar -->
    <RelativeLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_alignParentTop="true"
        android:paddingHorizontal="16dp"
        android:elevation="4dp">

        <TextView
            android:id="@+id/tvEditorTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Image Studio"
            android:textSize="20sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnExport"
            style="@style/ModernButtonStyle"
            android:layout_width="wrap_content"
            android:layout_height="50dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:layout_marginBottom="0dp"
            android:backgroundTint="#34C759"
            android:textColor="#FFFFFF"
            android:text="Export" />
    </RelativeLayout>

    <!-- Canvas Area -->
    <FrameLayout
        android:id="@+id/canvasContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/bottomMenuBar"
        android:layout_below="@+id/topBar"
        android:background="#80000000">

        <Button
            android:id="@+id/btnTapToStart"
            style="@style/ModernButtonStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginBottom="0dp"
            android:text="Tap Here to Load Base Image"
            android:backgroundTint="#4A90E2"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:paddingHorizontal="24dp"
            android:paddingVertical="12dp"
            android:elevation="6dp" />

        <TextView
            android:id="@+id/tvTapToStart"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone" />
    </FrameLayout>

    <!-- Left Panel -->
    <LinearLayout
        android:id="@+id/leftLayersPanel"
        android:layout_width="180dp"
        android:layout_height="match_parent"
        android:layout_above="@+id/bottomMenuBar"
        android:layout_below="@+id/topBar"
        android:layout_alignParentStart="true"
        android:orientation="vertical"
        android:padding="12dp"
        android:visibility="gone"
        android:elevation="6dp">

        <Button
            android:id="@+id/btnAddOverlay"
            style="@style/ModernButtonStyle"
            android:layout_width="match_parent"
            android:layout_height="45dp"
            android:backgroundTint="#4A90E2"
            android:textColor="#FFFFFF"
            android:text="+ Add Overlay" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/layersRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="12dp"
            android:scrollbars="none" />
    </LinearLayout>

    <!-- Right Panel -->
    <ScrollView
        android:id="@+id/rightToolsPanel"
        android:layout_width="180dp"
        android:layout_height="match_parent"
        android:layout_above="@+id/bottomMenuBar"
        android:layout_below="@+id/topBar"
        android:layout_alignParentEnd="true"
        android:visibility="gone"
        android:elevation="6dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <Button android:id="@+id/btnLoad" style="@style/ModernButtonStyle" android:layout_width="match_parent" android:text="Load Base" />
            <Button android:id="@+id/btnZoom" style="@style/ModernButtonStyle" android:layout_width="match_parent" android:text="Zoom/Pan: OFF" />
            <Button android:id="@+id/btnGrid" style="@style/ModernButtonStyle" android:layout_width="match_parent" android:text="Grid: OFF" />
            <Button android:id="@+id/btnUndo" style="@style/ModernButtonStyle" android:layout_width="match_parent" android:backgroundTint="#FF9F0A" android:textColor="#FFFFFF" android:text="Undo Last" />
            <Button android:id="@+id/btnCrop" style="@style/ModernButtonStyle" android:layout_width="match_parent" android:text="Crop Base" />
            <Button android:id="@+id/btnAdjust" style="@style/ModernButtonStyle" android:layout_width="match_parent" android:backgroundTint="#9C27B0" android:textColor="#FFFFFF" android:text="Adjust Image" />
            <Button android:id="@+id/btnBgRemover" style="@style/ModernButtonStyle" android:layout_width="match_parent" android:backgroundTint="#FF3B30" android:textColor="#FFFFFF" android:text="BG Remover" />
            <Button android:id="@+id/btnText" style="@style/ModernButtonStyle" android:layout_width="match_parent" android:text="Add Text" />
            <Button android:id="@+id/btnDraw" style="@style/ModernButtonStyle" android:layout_width="match_parent" android:text="Draw Tool" />

            <!-- Advanced Canvas Button -->
            <Button android:id="@+id/btnAdvancedCanvas" style="@style/ModernButtonStyle" android:layout_width="match_parent" android:backgroundTint="#E91E63" android:textColor="#FFFFFF" android:text="Pro Canvas" />

            <!-- NEW: Clone Tool Button -->
            <Button android:id="@+id/btnCloneTool" style="@style/ModernButtonStyle" android:layout_width="match_parent" android:backgroundTint="#FF9500" android:textColor="#FFFFFF" android:text="Clone Tool" />

            <!-- Layer Edit Button -->
            <Button android:id="@+id/btnLayerEdit" style="@style/ModernButtonStyle" android:layout_width="match_parent" android:backgroundTint="#4A90E2" android:textColor="#FFFFFF" android:text="Edit Layer" />

            <Button android:id="@+id/btnCopy" style="@style/ModernButtonStyle" android:layout_width="match_parent" android:text="Copy Layer" />
            <Button android:id="@+id/btnLayerOut" style="@style/ModernButtonStyle" android:layout_width="match_parent" android:text="Layer Out: OFF" />
            <Button android:id="@+id/btnClear" style="@style/ModernButtonStyle" android:layout_width="match_parent" android:text="Clear All" />
        </LinearLayout>
    </ScrollView>

    <!-- Crop Toolbar -->
    <HorizontalScrollView
        android:id="@+id/cropToolsBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="80dp"
        android:background="#99000000"
        android:visibility="gone"
        android:scrollbars="none"
        android:paddingVertical="8dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp"
            android:gravity="center_vertical">

            <Button android:id="@+id/btnCropCancel" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Cancel" android:backgroundTint="#FF3B30" android:textColor="#FFF" android:layout_marginEnd="8dp"/>
            <Button android:id="@+id/btnCropFree" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Free" android:backgroundTint="#4A90E2" android:textColor="#FFF" android:layout_marginEnd="8dp"/>
            <Button android:id="@+id/btnCropFull" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Full" android:backgroundTint="#4A90E2" android:textColor="#FFF" android:layout_marginEnd="8dp"/>
            <Button android:id="@+id/btnCrop1to1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="1:1" android:backgroundTint="#4A90E2" android:textColor="#FFF" android:layout_marginEnd="8dp"/>
            <Button android:id="@+id/btnCrop16to9" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="16:9" android:backgroundTint="#4A90E2" android:textColor="#FFF" android:layout_marginEnd="8dp"/>
            <Button android:id="@+id/btnCrop9to16" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="9:16" android:backgroundTint="#4A90E2" android:textColor="#FFF" android:layout_marginEnd="8dp"/>
            <Button android:id="@+id/btnCrop4to3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="4:3" android:backgroundTint="#4A90E2" android:textColor="#FFF" android:layout_marginEnd="8dp"/>
            <Button android:id="@+id/btnCrop4to1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="4:1" android:backgroundTint="#4A90E2" android:textColor="#FFF" android:layout_marginEnd="8dp"/>
            <Button android:id="@+id/btnCropCircle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Circle" android:backgroundTint="#4A90E2" android:textColor="#FFF" android:layout_marginEnd="8dp"/>
            <Button android:id="@+id/btnCropPerspective" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Perspective" android:backgroundTint="#9C27B0" android:textColor="#FFF" android:layout_marginEnd="8dp"/>
            <Button android:id="@+id/btnCropRotate" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Rotate" android:backgroundTint="#FF9500" android:textColor="#FFF" android:layout_marginEnd="8dp"/>
            <Button android:id="@+id/btnCropMirror" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Mirror" android:backgroundTint="#FF9500" android:textColor="#FFF" android:layout_marginEnd="8dp"/>
            <Button android:id="@+id/btnCropApply" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Apply" android:backgroundTint="#34C759" android:textColor="#FFF"/>
        </LinearLayout>
    </HorizontalScrollView>

    <!-- Bottom Menu Navigation -->
    <LinearLayout
        android:id="@+id/bottomMenuBar"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:padding="8dp"
        android:elevation="8dp">

        <Button
            android:id="@+id/btnToggleLayers"
            style="@style/ModernButtonStyle"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:layout_marginEnd="4dp"
            android:layout_marginBottom="0dp"
            android:text="Layers"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btnToggleTools"
            style="@style/ModernButtonStyle"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:layout_marginStart="4dp"
            android:layout_marginBottom="0dp"
            android:text="Editing Tools"
            android:textSize="14sp" />
    </LinearLayout>

</RelativeLayout>