<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/editorRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:ignore="HardcodedText,ButtonBarStyle">

    <!-- Canvas Area -->
    <FrameLayout
        android:id="@+id/canvasContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <Button
            android:id="@+id/btnTapToStart"
            style="@style/ModernButtonStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginBottom="0dp"
            android:text="Tap Here to Load Base Image"
            android:backgroundTint="#4A90E2"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:paddingHorizontal="32dp"
            android:paddingVertical="16dp"
            android:elevation="12dp" />

        <TextView
            android:id="@+id/tvTapToStart"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone" />
    </FrameLayout>

    <!-- PERFECTLY ALIGNED TOP BAR -->
    <RelativeLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_alignParentTop="true"
        android:paddingHorizontal="24dp"
        android:elevation="12dp">

        <Button
            android:id="@+id/btnGallery"
            android:layout_width="wrap_content"
            android:layout_height="45dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:paddingHorizontal="20dp"
            android:textSize="15sp"
            android:textStyle="bold"
            android:elevation="0dp"
            android:stateListAnimator="@null"
            android:text="Gallery" />

        <TextView
            android:id="@+id/tvEditorTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Image Studio"
            android:textSize="22sp"
            android:letterSpacing="0.05"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnExport"
            android:layout_width="wrap_content"
            android:layout_height="45dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:paddingHorizontal="24dp"
            android:textSize="15sp"
            android:textStyle="bold"
            android:elevation="0dp"
            android:stateListAnimator="@null"
            android:text="Export" />
    </RelativeLayout>

    <!-- PERFECT CAPSULE BOTTOM MENU -->
    <LinearLayout
        android:id="@+id/bottomMenuBar"
        android:layout_width="wrap_content"
        android:layout_height="55dp"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="32dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:elevation="0dp"
        android:clipToPadding="false">

        <Button
            android:id="@+id/btnToggleLayers"
            android:layout_width="130dp"
            android:layout_height="match_parent"
            android:layout_marginEnd="8dp"
            android:text="Layers"
            android:textSize="16sp"
            android:textStyle="bold"
            android:elevation="0dp"
            android:stateListAnimator="@null"/>

        <Button
            android:id="@+id/btnToggleTools"
            android:layout_width="130dp"
            android:layout_height="match_parent"
            android:layout_marginStart="8dp"
            android:text="Tools"
            android:textSize="16sp"
            android:textStyle="bold"
            android:elevation="0dp"
            android:stateListAnimator="@null"/>
    </LinearLayout>

    <!-- CROP TOOLBAR WRAPPER -->
    <FrameLayout
        android:id="@+id/cropToolsBar"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:layout_above="@+id/bottomMenuBar"
        android:layout_marginHorizontal="0dp"
        android:layout_marginBottom="16dp"
        android:visibility="gone"
        android:elevation="0dp"
        android:background="@android:color/transparent">

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scrollbars="none"
            android:paddingHorizontal="16dp"
            android:clipToPadding="false">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <Button android:id="@+id/btnCropCancel" style="@style/ModernButtonStyle" android:layout_width="wrap_content" android:minWidth="100dp" android:paddingHorizontal="20dp" android:layout_height="45dp" android:text="Cancel" android:backgroundTint="#FF3B30" android:textColor="#FFF" android:layout_marginEnd="12dp"/>
                <Button android:id="@+id/btnCropFree" style="@style/ModernButtonStyle" android:layout_width="wrap_content" android:minWidth="100dp" android:paddingHorizontal="20dp" android:layout_height="45dp" android:text="Free" android:backgroundTint="#4A90E2" android:textColor="#FFF" android:layout_marginEnd="12dp"/>
                <Button android:id="@+id/btnCropFull" style="@style/ModernButtonStyle" android:layout_width="wrap_content" android:minWidth="100dp" android:paddingHorizontal="20dp" android:layout_height="45dp" android:text="Full" android:backgroundTint="#4A90E2" android:textColor="#FFF" android:layout_marginEnd="12dp"/>
                <Button android:id="@+id/btnCrop1to1" style="@style/ModernButtonStyle" android:layout_width="wrap_content" android:minWidth="100dp" android:paddingHorizontal="20dp" android:layout_height="45dp" android:text="1:1" android:backgroundTint="#4A90E2" android:textColor="#FFF" android:layout_marginEnd="12dp"/>
                <Button android:id="@+id/btnCrop16to9" style="@style/ModernButtonStyle" android:layout_width="wrap_content" android:minWidth="100dp" android:paddingHorizontal="20dp" android:layout_height="45dp" android:text="16:9" android:backgroundTint="#4A90E2" android:textColor="#FFF" android:layout_marginEnd="12dp"/>
                <Button android:id="@+id/btnCrop9to16" style="@style/ModernButtonStyle" android:layout_width="wrap_content" android:minWidth="100dp" android:paddingHorizontal="20dp" android:layout_height="45dp" android:text="9:16" android:backgroundTint="#4A90E2" android:textColor="#FFF" android:layout_marginEnd="12dp"/>
                <Button android:id="@+id/btnCrop4to3" style="@style/ModernButtonStyle" android:layout_width="wrap_content" android:minWidth="100dp" android:paddingHorizontal="20dp" android:layout_height="45dp" android:text="4:3" android:backgroundTint="#4A90E2" android:textColor="#FFF" android:layout_marginEnd="12dp"/>
                <Button android:id="@+id/btnCrop4to1" style="@style/ModernButtonStyle" android:layout_width="wrap_content" android:minWidth="100dp" android:paddingHorizontal="20dp" android:layout_height="45dp" android:text="4:1" android:backgroundTint="#4A90E2" android:textColor="#FFF" android:layout_marginEnd="12dp"/>
                <Button android:id="@+id/btnCropCircle" style="@style/ModernButtonStyle" android:layout_width="wrap_content" android:minWidth="100dp" android:paddingHorizontal="20dp" android:layout_height="45dp" android:text="Circle" android:backgroundTint="#4A90E2" android:textColor="#FFF" android:layout_marginEnd="12dp"/>
                <Button android:id="@+id/btnCropPerspective" style="@style/ModernButtonStyle" android:layout_width="wrap_content" android:minWidth="100dp" android:paddingHorizontal="20dp" android:layout_height="45dp" android:text="Perspective" android:backgroundTint="#9C27B0" android:textColor="#FFF" android:layout_marginEnd="12dp"/>
                <Button android:id="@+id/btnCropRotate" style="@style/ModernButtonStyle" android:layout_width="wrap_content" android:minWidth="100dp" android:paddingHorizontal="20dp" android:layout_height="45dp" android:text="Rotate" android:backgroundTint="#FF9500" android:textColor="#FFF" android:layout_marginEnd="12dp"/>
                <Button android:id="@+id/btnCropMirror" style="@style/ModernButtonStyle" android:layout_width="wrap_content" android:minWidth="100dp" android:paddingHorizontal="20dp" android:layout_height="45dp" android:text="Mirror" android:backgroundTint="#FF9500" android:textColor="#FFF" android:layout_marginEnd="12dp"/>
                <Button android:id="@+id/btnCropApply" style="@style/ModernButtonStyle" android:layout_width="wrap_content" android:minWidth="100dp" android:paddingHorizontal="20dp" android:layout_height="45dp" android:text="Apply" android:backgroundTint="#34C759" android:textColor="#FFF"/>
            </LinearLayout>
        </HorizontalScrollView>
    </FrameLayout>

    <!-- INVISIBLE OVERLAY -->
    <View
        android:id="@+id/panelOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#1A000000"
        android:elevation="20dp"
        android:visibility="gone" />

    <!-- LEFT PANEL -->
    <LinearLayout
        android:id="@+id/leftLayersPanel"
        android:layout_width="260dp"
        android:layout_height="match_parent"
        android:layout_alignParentStart="true"
        android:paddingTop="32dp"
        android:paddingBottom="32dp"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:visibility="gone"
        android:elevation="30dp">

        <Button
            android:id="@+id/btnAddOverlay"
            style="@style/ModernButtonStyle"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:textSize="15sp"
            android:backgroundTint="#4A90E2"
            android:textColor="#FFFFFF"
            android:text="+ Add Overlay" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/layersRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="16dp"
            android:scrollbars="none"
            android:clipToPadding="false"
            android:paddingBottom="16dp"/>
    </LinearLayout>

    <!-- RIGHT PANEL -->
    <ScrollView
        android:id="@+id/rightToolsPanel"
        android:layout_width="260dp"
        android:layout_height="match_parent"
        android:layout_alignParentEnd="true"
        android:paddingTop="32dp"
        android:paddingBottom="32dp"
        android:visibility="gone"
        android:elevation="30dp"
        android:scrollbars="none"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp">

            <Button android:id="@+id/btnSaveDraft" style="@style/ModernButtonStyle" android:layout_width="match_parent" android:layout_height="55dp" android:layout_marginBottom="8dp" android:textSize="15sp" android:backgroundTint="#8A2BE2" android:textColor="#FFFFFF" android:text="Save Draft" />
            <Button android:id="@+id/btnLoad" style="@style/ModernButtonStyle" android:layout_width="match_parent" android:layout_height="55dp" android:layout_marginBottom="8dp" android:textSize="15sp" android:text="Load Base" />
            <Button android:id="@+id/btnZoom" style="@style/ModernButtonStyle" android:layout_width="match_parent" android:layout_height="55dp" android:layout_marginBottom="8dp" android:textSize="15sp" android:text="Zoom: OFF" />
            <Button android:id="@+id/btnGrid" style="@style/ModernButtonStyle" android:layout_width="match_parent" android:layout_height="55dp" android:layout_marginBottom="8dp" android:textSize="15sp" android:text="Grid: OFF" />

            <!-- HORIZONTAL UNDO & REDO BLOCK -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <Button android:id="@+id/btnUndo" style="@style/ModernButtonStyle" android:layout_width="0dp" android:layout_weight="1" android:layout_height="55dp" android:textSize="15sp" android:backgroundTint="#FF9F0A" android:textColor="#FFFFFF" android:text="Undo" android:layout_marginEnd="4dp"/>
                <Button android:id="@+id/btnRedo" style="@style/ModernButtonStyle" android:layout_width="0dp" android:layout_weight="1" android:layout_height="55dp" android:textSize="15sp" android:backgroundTint="#34C759" android:textColor="#FFFFFF" android:text="Redo" android:layout_marginStart="4dp"/>

            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#33888888" android:layout_marginVertical="12dp"/>

            <Button android:id="@+id/btnCrop" style="@style/ModernButtonStyle" android:layout_width="match_parent" android:layout_height="55dp" android:layout_marginBottom="8dp" android:textSize="15sp" android:text="Crop Base" />
            <Button android:id="@+id/btnAdjust" style="@style/ModernButtonStyle" android:layout_width="match_parent" android:layout_height="55dp" android:layout_marginBottom="8dp" android:textSize="15sp" android:backgroundTint="#9C27B0" android:textColor="#FFFFFF" android:text="Adjust Image" />
            <Button android:id="@+id/btnBgRemover" style="@style/ModernButtonStyle" android:layout_width="match_parent" android:layout_height="55dp" android:layout_marginBottom="8dp" android:textSize="15sp" android:backgroundTint="#FF3B30" android:textColor="#FFFFFF" android:text="BG Remover" />
            <Button android:id="@+id/btnText" style="@style/ModernButtonStyle" android:layout_width="match_parent" android:layout_height="55dp" android:layout_marginBottom="8dp" android:textSize="15sp" android:text="Add Text" />
            <Button android:id="@+id/btnDraw" style="@style/ModernButtonStyle" android:layout_width="match_parent" android:layout_height="55dp" android:layout_marginBottom="8dp" android:textSize="15sp" android:text="Draw Tool" />

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#33888888" android:layout_marginVertical="12dp"/>

            <Button android:id="@+id/btnAdvancedCanvas" style="@style/ModernButtonStyle" android:layout_width="match_parent" android:layout_height="55dp" android:layout_marginBottom="8dp" android:textSize="15sp" android:backgroundTint="#E91E63" android:textColor="#FFFFFF" android:text="Pro Canvas" />
            <Button android:id="@+id/btnCloneTool" style="@style/ModernButtonStyle" android:layout_width="match_parent" android:layout_height="55dp" android:layout_marginBottom="8dp" android:textSize="15sp" android:backgroundTint="#FF9500" android:textColor="#FFFFFF" android:text="Clone Tool" />
            <Button android:id="@+id/btnLayerEdit" style="@style/ModernButtonStyle" android:layout_width="match_parent" android:layout_height="55dp" android:layout_marginBottom="8dp" android:textSize="15sp" android:backgroundTint="#4A90E2" android:textColor="#FFFFFF" android:text="Edit Layer" />
            <Button android:id="@+id/btnCopy" style="@style/ModernButtonStyle" android:layout_width="match_parent" android:layout_height="55dp" android:layout_marginBottom="8dp" android:textSize="15sp" android:text="Copy Layer" />
            <Button android:id="@+id/btnLayerOut" style="@style/ModernButtonStyle" android:layout_width="match_parent" android:layout_height="55dp" android:layout_marginBottom="8dp" android:textSize="15sp" android:text="Layer Out: OFF" />
            <Button android:id="@+id/btnClear" style="@style/ModernButtonStyle" android:layout_width="match_parent" android:layout_height="55dp" android:layout_marginBottom="8dp" android:textSize="15sp" android:text="Clear All" />
        </LinearLayout>
    </ScrollView>

</RelativeLayout>