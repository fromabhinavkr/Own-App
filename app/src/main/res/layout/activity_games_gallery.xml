<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/gamesGalleryRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvGamesTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Games Collection"
        android:textSize="32sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp"
        android:layout_marginTop="24dp"/>

    <TextView
        android:id="@+id/tvGamesSubtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tap a game to start playing instantly."
        android:textSize="14sp"
        android:layout_marginBottom="24dp"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none">

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:alignmentMode="alignMargins">

            <LinearLayout
                android:id="@+id/cardSnakeGame"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:orientation="vertical"
                android:background="@drawable/bg_gallery_card"
                android:clipToOutline="true"
                android:layout_margin="8dp"
                android:elevation="2dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="140dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/snake_preview" />

                <TextView
                    android:id="@+id/textSnakeGame"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Play Snake"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:padding="16dp" />
            </LinearLayout>

        </GridLayout>
    </ScrollView>
</LinearLayout>