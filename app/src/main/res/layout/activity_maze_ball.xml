<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootMazeBall"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- The Retro Game Canvas -->
    <FrameLayout
        android:id="@+id/gameCanvasContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Modern HUD: Frosted Glass Pills -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="20dp"
        android:gravity="center_vertical"
        android:clipToPadding="false">

        <!-- Left HUD Pill (Lives) -->
        <LinearLayout
            android:id="@+id/hudLeft"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="20dp"
            android:paddingVertical="12dp"
            android:gravity="center"
            android:elevation="4dp">

            <TextView
                android:id="@+id/tvLives"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LIVES: 3"
                android:textColor="#FF4444"
                android:textSize="18sp"
                android:fontFamily="sans-serif-black" />
        </LinearLayout>

        <Space
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1" />

        <!-- Right HUD Pill (Scores) -->
        <LinearLayout
            android:id="@+id/hudRight"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingVertical="10dp"
            android:gravity="end"
            android:elevation="4dp">

            <TextView
                android:id="@+id/tvScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RINGS: 0000"
                android:textColor="#FFC107"
                android:textSize="18sp"
                android:fontFamily="sans-serif-black" />

            <TextView
                android:id="@+id/tvHighScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BEST: 0000"
                android:textColor="#888888"
                android:textSize="12sp"
                android:layout_marginTop="2dp"
                android:fontFamily="sans-serif-bold" />
        </LinearLayout>
    </LinearLayout>

    <!-- Bottom UI: Modern Floating Controls -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="24dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:layout_alignParentStart="true"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnLeft"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:text="◀"
                android:textSize="24sp"
                android:layout_marginEnd="16dp"
                android:elevation="4dp"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/btnRight"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:text="▶"
                android:textSize="24sp"
                android:elevation="4dp"
                android:stateListAnimator="@null" />
        </LinearLayout>

        <Button
            android:id="@+id/btnJump"
            android:layout_width="85dp"
            android:layout_height="85dp"
            android:layout_alignParentBottom="true"
            android:layout_alignParentEnd="true"
            android:text="▲"
            android:textSize="28sp"
            android:elevation="4dp"
            android:stateListAnimator="@null" />
    </RelativeLayout>

    <!-- MODERN MODE SELECTION OVERLAY -->
    <RelativeLayout
        android:id="@+id/modeSelectionOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:elevation="10dp">

        <LinearLayout
            android:id="@+id/modeSelectionCard"
            android:layout_width="320dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp"
            android:elevation="12dp">

            <TextView
                android:id="@+id/tvModeTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Select Mode"
                android:textSize="24sp"
                android:fontFamily="sans-serif-black"
                android:layout_marginBottom="32dp"/>

            <Button
                android:id="@+id/btnModeLandscape"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:text="Classic Runner"
                android:textAllCaps="false"
                android:textSize="18sp"
                android:fontFamily="sans-serif-bold"
                android:layout_marginBottom="16dp"
                android:stateListAnimator="@null"/>

            <Button
                android:id="@+id/btnModePortrait"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:text="Tower Climber"
                android:textAllCaps="false"
                android:textSize="18sp"
                android:fontFamily="sans-serif-bold"
                android:stateListAnimator="@null"/>
        </LinearLayout>
    </RelativeLayout>

    <!-- MODERN GAME OVER OVERLAY -->
    <RelativeLayout
        android:id="@+id/gameOverOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:gravity="center"
        android:elevation="10dp">

        <LinearLayout
            android:id="@+id/gameOverCard"
            android:layout_width="300dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp"
            android:elevation="12dp">

            <TextView
                android:id="@+id/tvGameOverTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Game Over"
                android:textSize="28sp"
                android:fontFamily="sans-serif-black"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvFinalScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Score: 0"
                android:textSize="20sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="32dp"/>

            <Button
                android:id="@+id/btnPlayAgain"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:text="Play Again"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:fontFamily="sans-serif-bold"
                android:layout_marginBottom="16dp"
                android:stateListAnimator="@null"/>

            <Button
                android:id="@+id/btnQuit"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:text="Quit"
                android:textAllCaps="false"
                android:textSize="18sp"
                android:fontFamily="sans-serif-bold"
                android:stateListAnimator="@null"/>
        </LinearLayout>
    </RelativeLayout>
</FrameLayout>