<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/toolsGalleryRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:clipToPadding="false"
    android:clipChildren="false"
    tools:ignore="HardcodedText">

    <TextView
        android:id="@+id/tvToolsTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/tools_gallery_title"
        android:textSize="32sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp"
        android:layout_marginTop="24dp"/>

    <TextView
        android:id="@+id/tvToolsSubtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/tools_gallery_subtitle"
        android:textSize="14sp"
        android:layout_marginBottom="24dp"/>

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="2"
        android:alignmentMode="alignMargins"
        android:clipToPadding="false"
        android:clipChildren="false">

        <!-- 1. Image Editor Card -->
        <LinearLayout
            android:id="@+id/cardImageEditor"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:orientation="vertical"
            android:layout_margin="12dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="120dp">
                <ImageView
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:layout_gravity="center"
                    android:scaleType="fitCenter"
                    android:src="@drawable/imagestudio_preview" />
            </FrameLayout>

            <!-- THE HORIZONTAL SEPARATOR LINE -->
            <View
                android:id="@+id/divImageEditor"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginHorizontal="0dp" />

            <TextView
                android:id="@+id/textImageEditor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Image Studio"
                android:textSize="16sp"
                android:textStyle="bold"
                android:gravity="center"
                android:padding="16dp" />
        </LinearLayout>

        <!-- 2. Collage Studio Card -->
        <LinearLayout
            android:id="@+id/cardCollageStudio"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:orientation="vertical"
            android:layout_margin="12dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="120dp">
                <ImageView
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:layout_gravity="center"
                    android:scaleType="fitCenter"
                    android:src="@drawable/collagestudio_preview" />
            </FrameLayout>

            <!-- THE HORIZONTAL SEPARATOR LINE -->
            <View
                android:id="@+id/divCollageStudio"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginHorizontal="0dp" />

            <TextView
                android:id="@+id/textCollageStudio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Collage Studio"
                android:textSize="16sp"
                android:textStyle="bold"
                android:gravity="center"
                android:padding="16dp" />
        </LinearLayout>

        <!-- 3. PDF Studio Card -->
        <LinearLayout
            android:id="@+id/cardPdfStudio"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:orientation="vertical"
            android:layout_margin="12dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="120dp">
                <ImageView
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:layout_gravity="center"
                    android:scaleType="fitCenter"
                    android:src="@drawable/pdfstudio_preview" />
            </FrameLayout>

            <!-- THE HORIZONTAL SEPARATOR LINE -->
            <View
                android:id="@+id/divPdfStudio"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginHorizontal="0dp" />

            <TextView
                android:id="@+id/textPdfStudio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="PDF Studio"
                android:textSize="16sp"
                android:textStyle="bold"
                android:gravity="center"
                android:padding="16dp" />
        </LinearLayout>

        <!-- 4. Sticker Maker Card -->
        <LinearLayout
            android:id="@+id/cardStickerMaker"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:orientation="vertical"
            android:layout_margin="12dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="120dp">
                <ImageView
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:layout_gravity="center"
                    android:scaleType="fitCenter"
                    android:src="@drawable/stickermaker_preview" />
            </FrameLayout>

            <!-- THE HORIZONTAL SEPARATOR LINE -->
            <View
                android:id="@+id/divStickerMaker"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginHorizontal="0dp" />

            <TextView
                android:id="@+id/textStickerMaker"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/whatsapp_sticker_title"
                android:textSize="16sp"
                android:textStyle="bold"
                android:gravity="center"
                android:padding="16dp" />
        </LinearLayout>

    </GridLayout>
</LinearLayout>