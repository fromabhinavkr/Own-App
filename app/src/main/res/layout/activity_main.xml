<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:fitsSystemWindows="true">

    <!-- 1. Dark/Light Mode Toggle (Fixed Top Left - Unchanged) -->
    <ImageButton
        android:id="@+id/btn_app_theme_toggle"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_alignParentStart="true"
        android:layout_alignParentTop="true"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/theme_toggle_desc"
        android:src="@drawable/ic_moon"
        android:scaleType="fitCenter"
        android:padding="8dp"
        tools:ignore="ImageContrastCheck" />

    <!-- 2. Earth (Globe) - Moved to Top Center, right below the Theme Toggle -->
    <com.example.ownphotoonwall.GlobeGLSurfaceView
        android:id="@+id/globe_view"
        android:layout_width="320dp"
        android:layout_height="320dp"
        android:layout_below="@id/btn_app_theme_toggle"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="200dp" />

    <!-- 3. The 3-Column Square Buttons (Anchored to the Bottom) -->
    <LinearLayout
        android:id="@+id/bottom_button_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:weightSum="3"
        android:layout_marginBottom="16dp">

        <!-- Widgets Square Button -->
        <Button
            android:id="@+id/btnPlaceWidget"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:background="@drawable/modern_button"
            android:text="@string/widget_gallery_button"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:textStyle="bold"
            android:elevation="0dp"
            android:stateListAnimator="@null" />

        <!-- Games Square Button -->
        <Button
            android:id="@+id/btnGames"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:layout_marginStart="6dp"
            android:background="@drawable/modern_button"
            android:text="Games"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:textStyle="bold"
            android:elevation="0dp"
            android:stateListAnimator="@null" />

        <!-- Tools Square Button -->
        <Button
            android:id="@+id/btnTools"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:background="@drawable/modern_button"
            android:text="@string/tools_gallery_button"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:textStyle="bold"
            android:elevation="0dp"
            android:stateListAnimator="@null" />

    </LinearLayout>

</RelativeLayout>