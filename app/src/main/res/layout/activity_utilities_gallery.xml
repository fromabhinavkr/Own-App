<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/utilitiesGalleryRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#1C1C1E"
    android:fitsSystemWindows="true">

    <TextView
        android:id="@+id/tvUtilitiesTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Utilities"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="4dp"
        android:layout_marginTop="24dp" />

    <TextView
        android:id="@+id/tvUtilitiesSubtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tap a utility tool to launch instantly."
        android:textSize="14sp"
        android:textColor="#AAAAAA"
        android:layout_marginBottom="24dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none">

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:alignmentMode="alignMargins">

            <!-- Private Browser Card -->
            <LinearLayout
                android:id="@+id/cardPrivateBrowser"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:orientation="vertical"
                android:background="@drawable/bg_gallery_card"
                android:clipToOutline="true"
                android:layout_margin="8dp"
                android:elevation="2dp"
                android:clickable="true"
                android:focusable="true">

                <!-- FIXED: Image scaling to display your custom logo perfectly -->
                <ImageView
                    android:id="@+id/ivBrowserPreview"
                    android:layout_width="match_parent"
                    android:layout_height="140dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/privatebrowser_icon"
                    android:padding="0dp" />

                <TextView
                    android:id="@+id/textPrivateBrowser"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Private Browser"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:padding="16dp"
                    android:textColor="#FFFFFF" />
            </LinearLayout>

        </GridLayout>
    </ScrollView>
</LinearLayout>