<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/pdfRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvPdfTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="PDF Studio"
        android:textSize="32sp"
        android:textStyle="bold"
        android:layout_marginBottom="32dp"
        android:layout_marginTop="24dp"/>

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="2"
        android:rowCount="2"
        android:alignmentMode="alignMargins"
        android:columnOrderPreserved="false"
        android:useDefaultMargins="true">

        <!-- Merge Card -->
        <LinearLayout
            android:id="@+id/btnMergePdf"
            android:layout_width="0dp"
            android:layout_height="160dp"
            android:layout_columnWeight="1"
            android:layout_margin="8dp"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔗"
                android:textSize="40sp"
                android:layout_marginBottom="12dp"/>
            <TextView
                android:id="@+id/tvMergeLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Merge PDFs"
                android:textStyle="bold"
                android:textSize="16sp"/>
        </LinearLayout>

        <!-- Split Card -->
        <LinearLayout
            android:id="@+id/btnSplitPdf"
            android:layout_width="0dp"
            android:layout_height="160dp"
            android:layout_columnWeight="1"
            android:layout_margin="8dp"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✂️"
                android:textSize="40sp"
                android:layout_marginBottom="12dp"/>
            <TextView
                android:id="@+id/tvSplitLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Split PDF"
                android:textStyle="bold"
                android:textSize="16sp"/>
        </LinearLayout>

        <!-- Compress Card -->
        <LinearLayout
            android:id="@+id/btnCompressPdf"
            android:layout_width="0dp"
            android:layout_height="160dp"
            android:layout_columnWeight="1"
            android:layout_margin="8dp"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🗜️"
                android:textSize="40sp"
                android:layout_marginBottom="12dp"/>
            <TextView
                android:id="@+id/tvCompressLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Compress"
                android:textStyle="bold"
                android:textSize="16sp"/>
        </LinearLayout>

        <!-- Gallery Card -->
        <LinearLayout
            android:id="@+id/btnPdfGallery"
            android:layout_width="0dp"
            android:layout_height="160dp"
            android:layout_columnWeight="1"
            android:layout_margin="8dp"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📁"
                android:textSize="40sp"
                android:layout_marginBottom="12dp"/>
            <TextView
                android:id="@+id/tvGalleryLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PDF Gallery"
                android:textStyle="bold"
                android:textSize="16sp"/>
        </LinearLayout>
    </GridLayout>
</LinearLayout>