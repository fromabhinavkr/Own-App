                <aapt:attr name="android:fillColor"><gradient android:type="linear" android:startX="13.5" android:startY="9.5" android:endX="15.5" android:endY="10.5"><item android:offset="0" android:color="#1A1A20" /><item android:offset="1" android:color="#2D2D35" /></gradient></aapt:attr>
            </path>
            <!-- 8R. Nose Bridge High -->
            <path android:strokeWidth="0.05" android:strokeColor="#2D2D35" android:pathData="M 12,8 L 13.5,10 L 12,12.5 Z">
                <aapt:attr name="android:fillColor"><gradient android:type="linear" android:startX="12" android:startY="8" android:endX="13.5" android:endY="12.5"><item android:offset="0" android:color="#C4C4C9" /><item android:offset="1" android:color="#70707C" /></gradient></aapt:attr>
            </path>
            <!-- 9R. Mid Cheek Inner -->
            <path android:strokeWidth="0.05" android:strokeColor="#2D2D35" android:pathData="M 15.5,9.5 L 14.5,10.5 L 13.5,13 L 16,11.5 Z">
                <aapt:attr name="android:fillColor"><gradient android:type="linear" android:startX="13.5" android:startY="9.5" android:endX="16" android:endY="13"><item android:offset="0" android:color="#70707C" /><item android:offset="1" android:color="#35353E" /></gradient></aapt:attr>
