    android:viewportHeight="24">

    <!-- 1. Global Drop Shadow -->
    <path
        android:pathData="M12,1a11,11 0 1,0 0,22a11,11 0 1,0 0,-22"
        android:fillColor="#66000000"
        android:translateY="0.5" />

    <!-- 2. Outer Raised Rim (3D Bevel Highlight) -->
